{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build zmmr",
			"type": "shell",
			"command": "clang++",
			"args": [
				"-std=c++17",
				"-I${workspaceFolder}/include",
				"${workspaceFolder}/src/main.cpp",
				"${workspaceFolder}/src/glad.c",
				"-o",
				"${workspaceFolder}/zmrr",
				"-L${workspaceFolder}/lib",
				"${workspaceFolder}/lib/libglfw.3.dylib",
				"-framework",
				"OpenGL"
			],
			"group": "build",
			"presentation": { "reveal": "always" }
		}
	]
}
